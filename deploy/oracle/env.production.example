OPENAI_API_KEY=COLE_SUA_CHAVE_OPENAI_AQUI
OPENAI_MODEL=gpt-4.1
PORT=3000
NODE_ENV=production

AMX_AUTH_ENABLED=true
AMX_ADMIN_USER=admin
AMX_ADMIN_PASSWORD=TROQUE_POR_SENHA_FORTE
AMX_SESSION_SECRET=TROQUE_POR_UM_SEGREDO_LONGO
AMX_SESSION_HOURS=12

# Use false enquanto estiver acessando por IP/http.
# Depois de configurar dominio com HTTPS, altere para true.
AMX_COOKIE_SECURE=false

# Pasta persistente da VPS.
AMX_DATA_DIR=/var/lib/amx-hub
