NODE_ENV=production
OPENAI_API_KEY=COLE_SUA_CHAVE_OPENAI_AQUI
OPENAI_MODEL=gpt-4.1

AMX_AUTH_ENABLED=true
AMX_ADMIN_USER=admin
AMX_ADMIN_PASSWORD=TROQUE_POR_SENHA_FORTE
AMX_SESSION_SECRET=TROQUE_POR_UM_SEGREDO_LONGO
AMX_SESSION_HOURS=12
AMX_COOKIE_SECURE=true

# No Render Free, deixe vazio para usar o armazenamento temporario do servico.
# Para uso definitivo, migrar para plano/provedor com persistencia real.
AMX_DATA_DIR=
