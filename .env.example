OPENAI_API_KEY=COLE_SUA_CHAVE_OPENAI_AQUI
OPENAI_MODEL=gpt-4.1
PORT=3000

# Local: pode ficar false. Hospedagem online: use true.
AMX_AUTH_ENABLED=false
AMX_ADMIN_USER=admin
AMX_ADMIN_PASSWORD=troque-esta-senha
AMX_SESSION_SECRET=troque-este-segredo
AMX_SESSION_HOURS=12

# Opcional na hospedagem: pasta persistente fora do codigo.
# Exemplo Linux: /var/data/amx-hub
AMX_DATA_DIR=
AMX_COOKIE_SECURE=false

# Supabase: use somente no servidor/hospedagem. Nunca exponha esta chave no navegador.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
AMX_REQUIRE_PERSISTENT_STORE=false
